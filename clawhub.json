{
  "emoji": "\u26a1",
  "requires": {
    "env": [
      "SIMMER_API_KEY"
    ],
    "pip": [
      "simmer-sdk"
    ]
  },
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "fastloop_trader.py"
  },
  "tunables": [
    {
      "env": "SIMMER_SPRINT_ENTRY",
      "type": "number",
      "default": 0.05,
      "range": [
        0.01,
        0.15
      ],
      "step": 0.01,
      "label": "Entry edge threshold"
    },
    {
      "env": "SIMMER_SPRINT_MOMENTUM",
      "type": "number",
      "default": 0.02,
      "range": [
        0.01,
        0.1
      ],
      "step": 0.01,
      "label": "Momentum threshold (%)"
    },
    {
      "env": "SIMMER_SPRINT_SCORE_THRESHOLD",
      "type": "number",
      "default": 0.55,
      "range": [
        0.3,
        0.9
      ],
      "step": 0.01,
      "label": "Entry score threshold"
    },
    {
      "env": "SIMMER_SPRINT_MAX_POSITION",
      "type": "number",
      "default": 2.5,
      "range": [
        1.0,
        25.0
      ],
      "step": 0.5,
      "label": "Max position size (USDC)"
    },
    {
      "env": "AUTOMATON_MAX_BET",
      "type": "number",
      "default": 2.5,
      "range": [
        1.0,
        25.0
      ],
      "step": 0.5,
      "label": "Automaton max bet clamp"
    },
    {
      "env": "SIMMER_SPRINT_LOOKBACK",
      "type": "number",
      "default": 5,
      "range": [
        1,
        60
      ],
      "step": 1,
      "label": "Lookback window (minutes)"
    },
    {
      "env": "SIMMER_SPRINT_MIN_TIME",
      "type": "number",
      "default": 120,
      "range": [
        30,
        240
      ],
      "step": 15,
      "label": "Minimum time remaining (seconds)"
    },
    {
      "env": "SIMMER_SPRINT_MAX_EXPOSURE",
      "type": "number",
      "default": 2.5,
      "range": [
        1.0,
        25.0
      ],
      "step": 0.5,
      "label": "Max open exposure (USDC)"
    },
    {
      "env": "SIMMER_SPRINT_TP",
      "type": "number",
      "default": 0.15,
      "range": [
        0.05,
        0.3
      ],
      "step": 0.01,
      "label": "Take profit (%)"
    },
    {
      "env": "SIMMER_SPRINT_SL",
      "type": "number",
      "default": 0.08,
      "range": [
        0.02,
        0.2
      ],
      "step": 0.01,
      "label": "Stop loss (%)"
    },
    {
      "env": "SIMMER_SPRINT_DAILY_LOSS",
      "type": "number",
      "default": 20.0,
      "range": [
        5.0,
        100.0
      ],
      "step": 5.0,
      "label": "Daily loss stop (USDC)"
    },
    {
      "env": "SIMMER_SPRINT_PAUSE_HOURS",
      "type": "number",
      "default": 24,
      "range": [
        1,
        48
      ],
      "step": 1,
      "label": "Pause after loss stop (hours)"
    },
    {
      "env": "SIMMER_SPRINT_RESOLVE_EXIT",
      "type": "number",
      "default": 60,
      "range": [
        5,
        120
      ],
      "step": 5,
      "label": "Near-expiry exit threshold (seconds)"
    }
  ]
}
